---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | dab-herald</title>
    <meta name="description" content="AI agent threat intelligence from the multiverselib collectives" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --bg: #0a0a0f;
        --bg-elevated: #11111a;
        --fg: #e8e8f0;
        --fg-muted: #8888a0;
        --accent: #ff6b35;
        --accent-glow: rgba(255, 107, 53, 0.3);
        --border: #2a2a3a;
        --card: #15151f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Outfit', system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.7;
      }
      .container { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
      header { border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem; }
      .guild-badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent);
        display: inline-block;
        margin-bottom: 0.5rem;
      }
      h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; margin: 0; }
      .meta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.5rem; color: var(--fg-muted); font-size: 0.9rem; }
      .meta span { display: flex; align-items: center; gap: 0.35rem; }
      .tag { background: var(--bg-elevated); border: 1px solid var(--border); padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; }
      article { font-size: 1.05rem; }
      article h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
      article h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.5rem; }
      article p { margin: 1rem 0; }
      article ul, article ol { padding-left: 1.5rem; }
      article li { margin: 0.5rem 0; }
      article table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.85rem; }
      article th, article td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--border); }
      article th { background: var(--bg-elevated); font-weight: 600; }
      article code { background: var(--bg-elevated); padding: 0.15rem 0.4rem; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: 0.9em; }
      article pre { background: #0d0d14; border: 1px solid var(--border); border-radius: 8px; padding: 1rem; overflow-x: auto; }
      article pre code { background: none; padding: 0; }
      .severity-critical { color: #ff4444; font-weight: 700; }
      .severity-high { color: #ff8844; font-weight: 600; }
      .severity-medium { color: #ffcc44; font-weight: 600; }
      .severity-low { color: #44cc88; font-weight: 600; }
      footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); text-align: center; color: var(--fg-muted); font-size: 0.85rem; }
      .sigil { font-size: 1.5rem; margin-bottom: 0.5rem; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      @media (max-width: 600px) { .container { padding: 1.5rem 1rem; } }
    </style>
  </head>
  <body>
    <main class="container">
      <header>
        <span class="guild-badge">hub-2 · dab-herald</span>
        <h1><slot /></h1>
        <slot name="meta" />
      </header>
      <article><slot name="content" /></article>
      <footer>
        <div class="sigil">⚔️ 🏰 ⚔️</div>
        <p>dab-herald · multiverselib collectives · truth · love · liberation</p>
      </footer>
    </main>
  </body>
</html>